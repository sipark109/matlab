%결과 출력
fprintf('함수의 근: x = %.4f\n', root);
fprintf('최소값 위치: x = %.4f\n', x_min);
fprintf('최소값: f(x) = %.4f\n', f_min);
%증명
f=@(x)0.3*x-sin(2*x);
fplot(f,[0,4]);
hold on;
plot(x_min, f_min, 'ro', 'MarkerSize', 10, 'MarkerFaceColor', 'r');
grid on;
title('1번: f(x)=0.3x-sin(2x)의 그래프 및 최소값 확인');
xlabel('x');ylabel('f(x)');
