%3번
%V = 10 in3에 대하여, fminbnd 함수를 사용하는 함수를 사용하여 면적 A를 최소화하는
%r값을 계산하라. 상응하는 높이 h의 값은 얼마인가?
global V;
V=10;
[r_opt,A_min]=fminbnd(@psi_25012699_func_3,0.1,5);
h_opt=(3*V)/(pi*r_opt^2);

fprintf('면적 A를 최소화하는 r: %f in\n ',r_opt);
fprintf('상응하는 높이 h: %f in\n',h_opt);
%r에 대한 A의 그래프를 그려서 해의 민감도를 조사하라

r_axis=linspace(0.5,5,100);
A_axis=arrayfun(@psi_25012699_func_3,r_axis);

plot(r_axis,A_axis,'LineWidth',1.5);
hold on;
plot(r_opt,A_min,'ro','MarkerSize', 8, 'MarkerFaceColor', 'r');
% 면적이 최소값에서 10% 증가한 지점 (1.1 * A_min) 표시
A_threshold=1.1*A_min;
yline(A_threshold,'--k','110% of A_{min}');

f_sens=@(r)psi_25012699_func_3(r)-A_threshold;
r_low=fzero(f_sens,r_opt*0.5);
r_high=fzero(f_sens,r_opt*1.5);

grid on
title('3번: r에 따른 면적 A의 변화(민감도 조사)');
xlabel('r(in)');
ylabel('A(in^2)');
legend('면적 A','최소값','10% 증가 한계선')

fprintf('\n[민감도 조사 결과]\n');
fprintf('면적이 10%% 증가하기 전까지 r은 %.4f in 에서 %.4f in 사이에서 움직일 수 있습니다.\n', r_low, r_high);
fprintf('즉, 최적값에서 왼쪽으로 %.4f in, 오른쪽으로 %.4f in 만큼 벗어날 수 있습니다.\n', r_opt-r_low, r_high-r_opt);
