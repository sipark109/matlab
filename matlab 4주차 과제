function [root_val,min_x,min_val] = psi_25012699_func_1()
%f(x)=0.3*x-sin(2*x)
f=@(x)0.3*x-sin(2*x);
%근 찾기:f(x)=0
root_val=fzero(f,[0.5,2]);
%최소값 찾기
[min_x,min_val]=fminbnd(f,0,4);
end

function t = psi_25012699_func_2(h,v0,g)
%주어진 높이h 초기속도v0 중력가소도 g를 입력받아
% 해당 높이에 도달하는 t를 계산
%h=v0*t-(0.5)*g*t^2
%(0.5)*g*t^2-v0*t+h=0
    coeffs=[0.5*g,-v0,h];
    t=roots(coeffs);
end

function A = psi_25012699_func_3(r)
    global V
    h=(3*V)./(pi*r.^2);
    A=pi*r.*sqrt(r.^2+h.^2);
end



%1번
