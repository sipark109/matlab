clear
clc
x=input('연결의 형태(직렬 또는 병렬)=  ','s')
n=input('저항의 개수= ')
R=zeros(1,n);
for i= 1:n
    R(i)=input('저항값= ');
end
total_R=0;
if strcmp(x,'직렬')
    for i=1:n
        total_R=total_R+R(i);
    end
    fprintf('등가 저항 R= %f\n',total_R)
elseif  strcmp(x,'병렬')
    for i=1:n
        total_R=total_R+1/R(i)
    end
    fprintf('등가 저항 R= %f\n',1/total_R)
end
