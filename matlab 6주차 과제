clear
clc
price= [19, 18, 22, 21, 25, 19, 17, 21, 27, 29];
a=0;b=0;c=1000;
for i=1:length(price)
    if price(i)<20
        c=c+100;
        a=a+price(i)*100;
    elseif price(i)>25
        c=c-100;
        b=b+price(i)*100;
    end
end
initial_value=1000*price(1);
final_value=(c*price(end))+(b-a);
d=final_value-initial_value;
fprintf('(a) 주식을 사는 데 소비한 금액: %.f\n',a)
fprintf('(b) 주식을 팔아서 얻어진 금액: %.f\n',b)
fprintf('(c) 10일째가 지난 후에 보유하고 있는 주식의 수: %.f\n',c)
fprintf('(d) 포트폴리오에서 총 가치의 증가분: %.f\n',d)


