#include<stdio.h>
#include<stdlib.h>
#pragma warning(disable:4996)
int main() {
	int a, b, c,total=0;
	scanf("%d %d %d", &a, &b, &c);
	if (a == b && b == c){
		total = 10000 + a * 1000;
	}
	else if(a==b){
		total = 1000 + a * 100;
	}
	else if (a == c) {
		total = 1000 + a * 100;
	}
	else if (c == b) {
		total = 1000 + b * 100;
	}
	else {
		int max = (a > b) ? a : b;
		max = (max > c) ? max : c;
		total = max * 100;
	}
	printf("%d", total);
	return 0;
}
