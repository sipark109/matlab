#include<stdio.h>
#include<stdlib.h>
#pragma warning(disable:4996)
int main() {
	int h, m;scanf("%d %d", &h, &m);
	if (m >= 45) {
		printf("%d %d\n", h, m-45);
	}
	else {
		if (h != 0) {
			h = h - 1;
			m = 60 - (45-m);
			printf("%d %d\n", h, m);
		}
		else {
			h = 23;
			m = 60 - (45 - m);
			printf("%d %d\n", h, m);
		}
	}
	return 0;
}
