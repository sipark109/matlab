#include<stdio.h>
#include<stdlib.h>
#include <string.h>
#pragma warning(disable:4996)
int main() {
	int n;scanf("%d", &n);
	int* a = (int*)malloc(sizeof(int) * n);
	for (int i = 0;i < n;i++) {
		scanf("%d", &a[i]);
	}
	int v,cnt=0;scanf("%d", &v);
	for (int i = 0;i < n;i++) {
		if (a[i] == v)
			cnt++;
	}
	printf("%d\n", cnt);
	free(a);
	return 0;
}
