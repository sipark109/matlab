#include<stdio.h>
#include<stdlib.h>
#include <string.h>
#pragma warning(disable:4996)
int main() {
	int n;
	scanf("%d", &n);
	int* a = (int*)malloc(sizeof(int) * n);
	for (int i = 0;i < n;i++) {
		scanf("%d", &a[i]);
	}
	int max = a[0], min = a[0];
	for (int i = 1;i < n;i++) {
		if (max < a[i])max = a[i];
		if (min > a[i])min = a[i];
	}
	printf("%d %d\n", min, max);
	free(a);
	return 0;
}
#include<stdio.h>
#include<stdlib.h>
#include <string.h>
#pragma warning(disable:4996)
int main() {
	int a[9];
	for (int i = 0;i < 9;i++) {
		scanf("%d", &a[i]);
	}
	int max = a[0], max_idx=1;
	for (int i = 1;i < 9;i++) {
		if (max < a[i]) {
			max = a[i];
			max_idx = i+1;
		}
	}
	printf("%d\n%d\n", max, max_idx);
	return 0;
}
#include<stdio.h>
#include<stdlib.h>
#pragma warning(disable:4996)
int main() {
	int n, m;
	scanf("%d %d", &n, &m);
	int* a = (int*)calloc(n,sizeof(int));
	int x=0, y=0,z=0;
	for (int i = 0;i < m;i++) {
		scanf("%d %d %d", &x, &y, &z);
		for (int j = x;j <= y;j++) {
			a[j-1] = z;
		}
	}
	for (int i = 0;i < n;i++) {
		printf("%d ", a[i]);
	}
	free(a);
	return 0;
}
